<header class='sheet-header'>
  <div class='headContainer'>
    <div class='pfpContainer'>
      <img
        class='profile-img'
        src='{{actor.img}}'
        data-edit='img'
        data-action='onEditImage'
        title='{{actor.name}}'
        height='150'
        width='100'
      />
    </div>
    <div class='statsContainer'>
      <input
        name='name'
        type='text'
        value='{{actor.name}}'
        placeholder='Name'
        class='nameInputField'
      />
      <div class='statsResources'>
        <div class='statsResourcesSub'>
          <label for='system.resources.hp.value' class='resource-label'>
          {{localize 'HP: '}}
          </label>
          <input
          type='number'
          name='system.resources.hp.value'
          value='{{system.resources.hp.value}}'
          max='{{system.resources.hp.max}}'
          class='statInputField'
          />
          <span> / </span>
          <input
          type='number'
          name='system.resources.hp.max'
          value='{{system.resources.hp.max}}'
          class='statInputField'
          />
        </div>
        <div class='statsResourcesSub'>
          <label for='system.resources.stamina.value' class='resource-label'>
          {{localize 'Stamina: '}}
          </label>
          <input
          type='number'
          name='system.resources.stamina.value'
          value='{{system.resources.stamina.value}}'
          max='{{system.resources.stamina.max}}'
          class='statInputField'
          />
          <span> / </span>
          <input
          type='number'
          name='system.resources.stamina.max'
          value='{{system.resources.stamina.max}}'
          class='statInputField'
          />
        </div>
        <div class='statsResourcesSub'>
          <label for='system.xp.value' class='resource-label'>
          {{localize 'XP: '}}
          </label>
          <input
          type='number'
          name='system.xp.value'
          value='{{system.xp.value}}'
          class='statInputField'
          />
        </div>
      </div>
      <div class='statsResources'>
        <div class='statsResourcesSub'>
          <label for='system.def' class='resource-label'>
          {{localize 'DEF: '}}
          </label>
          <input
          type='number'
          name='system.def'
          value='{{system.def}}'
          class='statInputField'
          />
        </div>
        <div class='statsResourcesSub'>
          <label for='system.eva' class='resource-label'>
          {{localize 'EVA: '}}
          </label>
          <input
          type='number'
          name='system.eva'
          value='{{system.eva}}'
          class='statInputField'
          />
        </div>
        <div class='statsResourcesSub'>
          <label for='system.spd.value' class='resource-label'>
          {{localize 'SPD: '}}
          </label>
          <input
          type='number'
          name='system.spd.value'
          value='{{system.spd.value}}'
          class='statInputField'
          />
        </div>
      </div>
    </div>
  </div>
</header>